# Server
PORT=3456
DASHBOARD_PUBLIC_BASE_URL=http://192.168.1.100:3456
DASHBOARD_SHARED_OUT=./output

# Optional access control. Set at least one auth mode before exposing the service.
DASHBOARD_AUTH_USER=admin
DASHBOARD_AUTH_PASSWORD=change-me
DASHBOARD_API_TOKEN=change-me-api-token
API_RUN_CONCURRENCY=1
API_RUN_HISTORY_LIMIT=1000

# Optional integrations
NETEASE_API_BASE=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
